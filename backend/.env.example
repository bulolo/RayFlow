# ==============================================================================
# RayFlow environment template
# ==============================================================================
# This file is optimized for Docker Compose application services. `make dev-init`
# copies it to `backend/.env`. Production initialization copies the same template
# to `deploy/.env` and then replaces sensitive defaults.

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=dev
RAYFLOW_VERSION=0.0.4
# Business default timezone only. It is used by scheduler workflow defaults and
# seed data initialization. Database, JDBC, JVM default timezone, and JSON
# serialization remain UTC for consistency.
RAYFLOW_TIMEZONE=Asia/Shanghai

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
# Compose services resolve dependencies by service name. `make run-backend`
# overrides these to localhost:5433 for host-side execution.
DB_HOST=postgres
DB_PORT=5432
DB_NAME=rayflow
DB_USER=rayflow
DB_PASSWORD=rayflow123

# ------------------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# ------------------------------------------------------------------------------
# Security and bootstrap users
# ------------------------------------------------------------------------------
JWT_SECRET=change-this-to-a-random-secret-at-least-32-bytes
RAYFLOW_SECRET_ENCRYPTION_KEY=change-this-to-a-random-secret-encryption-key
RAYFLOW_SUPER_ADMIN_USERNAME=superadmin@rayflow.cn
RAYFLOW_SUPER_ADMIN_PASSWORD=change-me-before-start
RAYFLOW_DEFAULT_TENANT_ADMIN_USERNAME=admin@rayflow.cn
RAYFLOW_DEFAULT_TENANT_ADMIN_PASSWORD=change-me-before-start

# ------------------------------------------------------------------------------
# SQL preview callback
# ------------------------------------------------------------------------------
RAYFLOW_PREVIEW_CALLBACK_BASE_URL=
RAYFLOW_PREVIEW_CALLBACK_TOKEN=change-this-to-a-random-preview-callback-token
RAYFLOW_PREVIEW_WAIT_TIMEOUT_MS=60000

# ------------------------------------------------------------------------------
# Artifact and lake object storage
# ------------------------------------------------------------------------------
RAYFLOW_ARTIFACT_S3_ENDPOINT=http://rustfs:9000
RAYFLOW_ARTIFACT_S3_ACCESS_KEY=rustfsadmin
RAYFLOW_ARTIFACT_S3_SECRET_KEY=rustfsadmin
RAYFLOW_ARTIFACT_S3_BUCKET=rayflow-artifacts
RAYFLOW_LAKE_S3_BUCKET=rayflow-lake
RAYFLOW_ARTIFACT_S3_REGION=us-east-1
RAYFLOW_ARTIFACT_S3_PATH_STYLE=true

# ------------------------------------------------------------------------------
# Built-in Flink Docker runtime
# ------------------------------------------------------------------------------
# `make setup-flink-paimon` uses these versions to prepare
# deploy/docker/flink/custom-lib and keeps FLINK_IMAGE/RayFlow runtime settings in sync.
FLINK_VERSION=2.2.1
PAIMON_VERSION=1.4.2
PAIMON_FLINK_MINOR=2.2
FLINK_CDC_VERSION=3.5.0
FLINK_KAFKA_CONNECTOR_VERSION=5.0.0-2.2
MYSQL_DRIVER_VERSION=8.0.27
FLINK_HADOOP_SHADED_VERSION=2.8.3-10.0
FLINK_IMAGE=flink:2.2.1
FLINK_LIB_DIR=./deploy/docker/flink/custom-lib
FLINK_REST_PORT=8081
FLINK_SQL_GATEWAY_PORT=8083

# ------------------------------------------------------------------------------
# Backend Flink integration
# ------------------------------------------------------------------------------
RAYFLOW_BUILTIN_FLINK_RUNTIME_NAME=内置
RAYFLOW_BUILTIN_FLINK_REST_URL=http://flink-jobmanager:8081
RAYFLOW_BUILTIN_FLINK_SQL_GATEWAY_URL=http://flink-sql-gateway:8083
RAYFLOW_BUILTIN_FLINK_VERSION=2.2.1
RAYFLOW_BUILTIN_FLINK_IMAGE=flink:2.2.1
FLINK_REST_CONNECT_TIMEOUT_MS=3000
FLINK_REST_READ_TIMEOUT_MS=120000
FLINK_REST_SUBMIT_READ_TIMEOUT_MS=300000
FLINK_SQL_RUNNER_JAR=

# ------------------------------------------------------------------------------
# Paimon resource browser
# ------------------------------------------------------------------------------
# Metadata cache only covers database/table/schema. Manual refresh uses
# refresh=true to bypass this cache. Preview and snapshots are queried live.
RAYFLOW_PAIMON_BROWSER_CACHE_TTL_MS=10800000
RAYFLOW_PAIMON_BROWSER_OPERATION_TIMEOUT_MS=30000

# ------------------------------------------------------------------------------
# Scheduler
# ------------------------------------------------------------------------------
RAYFLOW_SCHEDULER_INSTANCE_ID=local

# ------------------------------------------------------------------------------
# Kubernetes integration
# ------------------------------------------------------------------------------
RAYFLOW_KUBECONFIG_DIR=${HOME}/.kube
KUBECONFIG=/root/.kube/config
